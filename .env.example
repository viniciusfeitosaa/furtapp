# Hair try-on (Fase 2 — Banuba)
# Sem token/effect, o site usa MediaPipe segment-tint (Fase 1).

# auto | segment-tint | banuba
NEXT_PUBLIC_HAIR_TRYON_PROVIDER=auto

# Trial: https://www.banuba.com/face-filters-sdk ou info@banuba.com
NEXT_PUBLIC_BANUBA_CLIENT_TOKEN=

# Effect Makeup (hair color) — arquivo .zip local em /public ou URL
# Ex.: /effects/Makeup.zip
NEXT_PUBLIC_BANUBA_MAKEUP_EFFECT_URL=

# OU base de estilos clínicos (hairstyle zips): curto.zip, classico.zip, ...
# Ex.: /effects/hair
NEXT_PUBLIC_BANUBA_STYLES_BASE=

# Opcional — default jsDelivr @banuba/webar@1.17.0
# NEXT_PUBLIC_BANUBA_SDK_CDN=https://cdn.jsdelivr.net/npm/@banuba/webar@1.17.0
